generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model User {
    id       String @id @default(cuid())
    email    String @unique
    password String
    name     String
    role     Role   @default(USER)

    // relation
    teamId String?
    team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

    // timestamps
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // indexes
    @@index([email])
    @@index([role])
    @@index([teamId])
    @@map("users")
}

model Team {
    id          String  @id @default(cuid())
    name        String  @unique
    description String?
    code        String  @unique
    members     User[]

    @@map("teams")
}

enum Role {
    ADMIN
    MANAGER
    USER
}
